PORT=4310

# Production app URL (OAuth redirects, Stripe success/cancel URLs)
# APP_URL=https://app.codetruth.io

# Session signing secret (required in production)
# SESSION_SECRET=generate-a-long-random-string

# Uncomment to use PostgreSQL (requires: npm run db:up && npm run db:push)
# DATABASE_URL=postgresql://codetruth:codetruth@localhost:5432/codetruth

# --- Authentication (Phase A SaaS) ---
# GitHub OAuth: https://github.com/settings/developers
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Dev-only email login (disabled automatically in production without OAuth)
# AUTH_DEV_EMAIL_LOGIN=true

# --- Stripe billing ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_TEAM_MONTHLY=price_...

# --- Phase B: Closed beta + telemetry ---
# BETA_MODE=true
# BETA_ADMIN_TOKEN=generate-admin-token
# BETA_DEFAULT_INVITE_CODE=MONAD-2026
# BETA_DEFAULT_INVITE_MAX=50
# BETA_DEFAULT_GRANTS_PLAN=pro
# BETA_DEFAULT_TRIAL_DAYS=45

# Redis job queue — when set, analyses run in the background worker (apps/worker).
# If Redis is configured but unreachable, the API falls back to inline analysis.
# REDIS_URL=redis://localhost:6379
# ANALYSIS_WORKER_CONCURRENCY=2

# GitHub PAT ingestion (legacy mode)
# GITHUB_TOKEN=ghp_...

# GitHub App (preferred for production — Phase D)
# 1. Create app at https://github.com/settings/apps/new
# 2. Save private key as github-app.pem (gitignored)
# 3. Webhook URL: {PUBLIC_API_URL}/webhooks/github
# 4. Events: push, installation, installation_repositories
# 5. Permissions: Contents (read), Metadata (read)
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=codetruth-os
# GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# GITHUB_APP_WEBHOOK_SECRET=your-app-webhook-secret

# Public API URL for GitHub webhooks + CI quality gate (required in production)
# PUBLIC_API_URL=https://api.codetruth.io

# Multi-LLM Truth Council (OpenAI-compatible API)
# Run: npm run setup:env
# LLM_API_KEY=sk-...

# Production failover when primary provider returns 429/quota errors:
# LLM_FALLBACK_API_KEY=sk-...
# LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_FALLBACK_NAME=openai-fallback

# Or explicit provider chain (JSON array, tried in order):
# LLM_PROVIDER_CHAIN=[{"name":"kimi","baseUrl":"https://api.kimi.com/coding/v1","apiKey":"sk-kimi-...","model":"kimi-for-coding"},{"name":"openai","baseUrl":"https://api.openai.com/v1","apiKey":"sk-...","model":"gpt-4o-mini"}]

# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Kimi Code API (sk-kimi-* keys)
# LLM_BASE_URL=https://api.kimi.com/coding/v1
# LLM_MODEL=kimi-for-coding

# Kimi Open Platform
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=kimi-k2.5

# Per-model overrides (adversarial multi-LLM council):
# LLM_MODEL_ARCHITECTURE_MODEL=gpt-4o-mini
# LLM_MODEL_RUNTIME_MODEL=gpt-4o
# LLM_MODEL_DEVOPS_MODEL=gpt-4o-mini
# LLM_MODEL_SECURITY_MODEL=gpt-4o-mini
# LLM_MODEL_PLANNING_MODEL=gpt-4o-mini
# LLM_MODEL_CONSENSUS=gpt-4o

# HMAC signing key for approved reports (change in production)
# REPORT_SIGNING_SECRET=your-signing-secret