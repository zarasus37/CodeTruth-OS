generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id
  email             String            @unique
  displayName       String            @map("display_name")
  apiToken          String            @unique @map("api_token")
  authProvider      String?           @map("auth_provider")
  githubId          String?           @unique @map("github_id")
  googleId          String?           @unique @map("google_id")
  entraId           String?           @unique @map("entra_id")
  oktaId            String?           @unique @map("okta_id")
  avatarUrl         String?           @map("avatar_url")
  betaAccessAt      DateTime?         @map("beta_access_at")
  betaInviteCode    String?           @map("beta_invite_code")
  createdAt         DateTime          @default(now()) @map("created_at")
  memberships       WorkspaceMember[]
  auditEntries      AuditLogEntry[]
  createdWorkspaces Workspace[]       @relation("WorkspaceCreator")
  sessions          AuthSession[]
  onboarding        UserOnboarding?
  betaRedemptions   BetaRedemption[]

  @@map("users")
}

model UserOnboarding {
  userId                   String    @id @map("user_id")
  completedSteps           Json      @default("[]") @map("completed_steps")
  firstAnalysisCompletedAt DateTime? @map("first_analysis_completed_at")
  activationSurvey         Json?     @map("activation_survey")
  activationSurveyAt       DateTime? @map("activation_survey_at")
  completedAt              DateTime? @map("completed_at")
  updatedAt                DateTime  @map("updated_at")
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_onboarding")
}

model ProductEvent {
  id          String   @id
  event       String
  userId      String?  @map("user_id")
  workspaceId String?  @map("workspace_id")
  projectId   String?  @map("project_id")
  analysisId  String?  @map("analysis_id")
  properties  Json?
  timestamp   DateTime @default(now())

  @@index([event, timestamp(sort: Desc)])
  @@index([userId, timestamp(sort: Desc)])
  @@map("product_events")
}

model BetaInvite {
  id               String           @id
  code             String           @unique
  label            String?
  maxRedemptions   Int              @map("max_redemptions")
  redemptionCount  Int              @default(0) @map("redemption_count")
  grantsPlan       String           @map("grants_plan")
  trialDays        Int              @default(30) @map("trial_days")
  expiresAt        DateTime?        @map("expires_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  redemptions      BetaRedemption[]

  @@map("beta_invites")
}

model BetaRedemption {
  id         String    @id
  inviteId   String    @map("invite_id")
  userId     String    @map("user_id")
  workspaceId String?  @map("workspace_id")
  redeemedAt DateTime  @map("redeemed_at")
  invite     BetaInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("beta_redemptions")
}

model AuthSession {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Workspace {
  id           String                 @id
  name         String
  settings     Json?
  createdAt    DateTime               @default(now()) @map("created_at")
  createdBy    String                 @map("created_by")
  creator      User                   @relation("WorkspaceCreator", fields: [createdBy], references: [id])
  members      WorkspaceMember[]
  projects     Project[]
  auditEntries AuditLogEntry[]
  subscription WorkspaceSubscription?
  usageRecords WorkspaceUsage[]
  engagements  DueDiligenceEngagement[]

  @@map("workspaces")
}

model DueDiligenceEngagement {
  id          String    @id
  workspaceId String    @map("workspace_id")
  projectId   String    @map("project_id")
  analysisId  String?   @map("analysis_id")
  title       String
  clientName  String?   @map("client_name")
  stage       String
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime  @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("due_diligence_engagements")
}

model WorkspaceSubscription {
  workspaceId          String    @id @map("workspace_id")
  plan                 String
  status               String
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  currentPeriodEnd     DateTime? @map("current_period_end")
  seatCount            Int?      @map("seat_count")
  updatedAt            DateTime  @map("updated_at")
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_subscriptions")
}

model WorkspaceUsage {
  workspaceId      String   @map("workspace_id")
  period           String
  analysesCount    Int      @default(0) @map("analyses_count")
  llmCouncilRuns   Int      @default(0) @map("llm_council_runs")
  projectsCreated  Int      @default(0) @map("projects_created")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, period])
  @@map("workspace_usage")
}

model WorkspaceMember {
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  joinedAt    DateTime  @default(now()) @map("joined_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id               String     @id
  workspaceId      String     @map("workspace_id")
  name             String
  createdAt        DateTime   @default(now()) @map("created_at")
  latestSnapshotId String?    @map("latest_snapshot_id")
  githubConfig     Json?      @map("github_config")
  workspace        Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analyses         Analysis[]

  @@index([workspaceId])
  @@map("projects")
}

model Analysis {
  id          String    @id
  projectId   String    @map("project_id")
  snapshotId  String    @map("snapshot_id")
  status      String
  progress    Int       @default(0)
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  artifacts   Json?
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("analyses")
}

model AuditLogEntry {
  id           String    @id
  workspaceId  String    @map("workspace_id")
  userId       String    @map("user_id")
  action       String
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id")
  timestamp    DateTime  @default(now())
  metadata     Json?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@index([workspaceId, timestamp(sort: Desc)])
  @@map("audit_log_entries")
}

model FindingReview {
  id          String   @id
  analysisId  String   @map("analysis_id")
  findingId   String   @map("finding_id")
  workspaceId String   @map("workspace_id")
  status      String
  rationale   String?
  deferUntil  DateTime? @map("defer_until")
  reviewedBy  String   @map("reviewed_by")
  reviewedAt  DateTime @map("reviewed_at")

  @@unique([analysisId, findingId])
  @@index([analysisId])
  @@map("finding_reviews")
}

model FindingAnnotation {
  id          String   @id
  analysisId  String   @map("analysis_id")
  findingId   String   @map("finding_id")
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  body        String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([analysisId, findingId])
  @@map("finding_annotations")
}

model ReportApproval {
  id              String    @id
  analysisId      String    @unique @map("analysis_id")
  workspaceId     String    @map("workspace_id")
  status          String
  submittedBy     String?   @map("submitted_by")
  submittedAt     DateTime? @map("submitted_at")
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  rationale       String?
  signature       String?
  signedAt        DateTime? @map("signed_at")
  analyzerVersion String    @map("analyzer_version")

  @@index([workspaceId])
  @@map("report_approvals")
}

model ReAnalysisSchedule {
  id          String    @id
  workspaceId String    @map("workspace_id")
  projectId   String    @map("project_id")
  enabled     Boolean   @default(true)
  interval    String
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")

  @@unique([workspaceId, projectId])
  @@index([workspaceId])
  @@map("reanalysis_schedules")
}

model ComplianceAttestation {
  id          String    @id
  workspaceId String    @map("workspace_id")
  projectId   String?   @map("project_id")
  framework   String
  attestedBy  String    @map("attested_by")
  attestedAt  DateTime  @map("attested_at")
  expiresAt   DateTime? @map("expires_at")
  signature   String?
  notes       String?

  @@index([workspaceId])
  @@map("compliance_attestations")
}

model CognitionActivity {
  id          String   @id
  workspaceId String   @map("workspace_id")
  projectId   String?  @map("project_id")
  analysisId  String?  @map("analysis_id")
  type        String
  timestamp   DateTime @default(now())
  summary     String
  metadata    Json?

  @@index([workspaceId, timestamp(sort: Desc)])
  @@map("cognition_activity")
}

model CustomCompliancePolicy {
  id                String   @id
  workspaceId       String   @map("workspace_id")
  title             String
  description       String
  domains           Json
  gapCategories     Json?    @map("gap_categories")
  severityThreshold String   @map("severity_threshold")
  createdAt         DateTime @default(now()) @map("created_at")
  createdBy         String   @map("created_by")

  @@index([workspaceId])
  @@map("custom_compliance_policies")
}